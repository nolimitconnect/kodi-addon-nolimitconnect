<?xml version="1.0" encoding="UTF-8"?>
<addon id="service.binary.nolimitconnect"
       name="NoLimitConnect"
      version="0.1.2"
       provider-name="NoLimitConnect Project">
  <requires>
    <import addon="xbmc.addon" version="21.0.0" />
    <import addon="xbmc.python" version="3.0.0" />
  </requires>

  <extension point="xbmc.service" library="resources/lib/service.py" start="login" />

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">NoLimitConnect binary add-on for Kodi</summary>
    <description lang="en_GB">Decentralized communication and media sharing via NoLimitConnect plugins inside Kodi.</description>
    <platform>linux</platform>
    <license>NO-LIMITCONNECT-CUSTOM</license>
    <source>https://github.com/nolimitconnect/kodi-addon-nolimitconnect</source>
    <website>https://nolimitconnect.org</website>
  </extension>
</addon>
